# Troque todas as credenciais antes de qualquer piloto ou implantação.
RAG_AUDIT_ENV=development
RAG_AUDIT_DB_PATH=data/rag_audit.db
RAG_AUDIT_CAMERA_API_KEY=dev-camera-key
RAG_AUDIT_ADMIN_USERNAME=admin
RAG_AUDIT_ADMIN_PASSWORD=change-me
RAG_AUDIT_TIMEZONE=America/Sao_Paulo
RAG_AUDIT_SEED_DEMO_DATA=true

# Em produção, use true. Eventos antigos devem entrar por um fluxo de importação separado.
RAG_AUDIT_ENFORCE_EVENT_FRESHNESS=false
RAG_AUDIT_EVENT_MAX_AGE_SECONDS=300
RAG_AUDIT_EVENT_FUTURE_SKEW_SECONDS=60

# Webhook genérico de Teams/Slack/Telegram/automação. Vazio mantém o alerta na outbox.
RAG_AUDIT_ALERT_WEBHOOK_URL=
RAG_AUDIT_ALERT_CHANNEL=generic-webhook
# false envia somente ID pseudônimo + contexto mínimo; habilite PII apenas após aprovação.
RAG_AUDIT_ALERT_INCLUDE_PERSONAL_DATA=false
RAG_AUDIT_PUBLIC_BASE_URL=http://127.0.0.1:8000
RAG_AUDIT_ALERT_TIMEOUT_SECONDS=2
RAG_AUDIT_ALERT_POLL_SECONDS=5
RAG_AUDIT_ALERT_MAX_ATTEMPTS=3
RAG_AUDIT_REPORT_LIMIT=5000
RAG_AUDIT_POLICY_VERSION=2026.1

# Intelbras VIPC 1230 G2. Preencha somente no .env local; nunca envie a senha por chat.
INTELBRAS_CAMERA_HOST=
INTELBRAS_CAMERA_USER=
INTELBRAS_CAMERA_PASSWORD=
INTELBRAS_CAMERA_RTSP_PORT=554
INTELBRAS_CAMERA_CHANNEL=1
INTELBRAS_CAMERA_SUBTYPE=0
INTELBRAS_CAMERA_TIMEOUT_SECONDS=5
INTELBRAS_CAMERA_CAPTURE_FRAME=1

# Worker local de reconhecimento e confirmação visual.
RAG_AUDIT_API_BASE_URL=http://127.0.0.1:8000
RAG_AUDIT_VISION_CAMERA_ID=cam-ti-01
RAG_AUDIT_VISION_ROOM_ID=sala_ti_01
RAG_AUDIT_GALLERY_MANIFEST=data/private/gallery/manifest.json
RAG_AUDIT_CAMERA_CALIBRATION=data/private/camera-calibration.json
RAG_AUDIT_VISION_MODELS_DIR=data/vision-models
RAG_AUDIT_VISION_OUTBOX_PATH=data/private/vision-outbox.db
RAG_AUDIT_VISION_SAMPLE_FPS=4
RAG_AUDIT_VISION_DRY_RUN=true

# Valores iniciais de laboratório; devem ser calibrados com entradas reais.
RAG_AUDIT_FACE_SIMILARITY_THRESHOLD=0.55
RAG_AUDIT_FACE_MARGIN_THRESHOLD=0.08
RAG_AUDIT_FACE_QUALITY_THRESHOLD=0.40
