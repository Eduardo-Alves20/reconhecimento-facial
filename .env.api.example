# Copie para .env.api e troque todas as credenciais antes de iniciar a API.
RAG_AUDIT_ENV=production
RAG_AUDIT_DB_PATH=data/api/rag_audit.db
RAG_AUDIT_VISION_EVIDENCE_DIR=data/private/evidence
RAG_AUDIT_ADMIN_USERNAME=admin
RAG_AUDIT_ADMIN_PASSWORD=replace-with-a-strong-admin-password
RAG_AUDIT_TIMEZONE=America/Sao_Paulo
RAG_AUDIT_SEED_DEMO_DATA=false

# Em produção, cada câmera usa uma chave própria com pelo menos 32 caracteres.
RAG_AUDIT_CAMERA_API_KEYS_JSON={"cam-ti-01":"replace-with-a-random-camera-key-at-least-32-characters"}

RAG_AUDIT_ENFORCE_EVENT_FRESHNESS=true
RAG_AUDIT_EVENT_MAX_AGE_SECONDS=300
RAG_AUDIT_EVENT_FUTURE_SKEW_SECONDS=60
# Eventos que ficaram na outbox podem usar uma janela maior, ainda limitada.
RAG_AUDIT_QUEUED_EVENT_MAX_AGE_SECONDS=604800

# Deve ser idêntico ao bloco de evidências do worker.
RAG_AUDIT_EVIDENCE_TTL_DAYS=30
RAG_AUDIT_EVIDENCE_MAX_GB=10
RAG_AUDIT_EVIDENCE_MAX_ITEM_MB=25
RAG_AUDIT_EVIDENCE_EVICT_OLDEST=true

# Vazio mantém o alerta na outbox da API. Em produção, use somente HTTPS.
RAG_AUDIT_ALERT_WEBHOOK_URL=
RAG_AUDIT_ALERT_CHANNEL=generic-webhook
RAG_AUDIT_ALERT_INCLUDE_PERSONAL_DATA=false
RAG_AUDIT_PUBLIC_BASE_URL=https://audit.example.internal
RAG_AUDIT_ALERT_TIMEOUT_SECONDS=2
RAG_AUDIT_ALERT_POLL_SECONDS=5
RAG_AUDIT_ALERT_MAX_ATTEMPTS=3
RAG_AUDIT_REPORT_LIMIT=5000
RAG_AUDIT_POLICY_VERSION=2026.1
