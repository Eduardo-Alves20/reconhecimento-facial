# Copie para .env.vision. Nunca envie a senha RTSP ou a chave da API ao Git.
INTELBRAS_CAMERA_HOST=
INTELBRAS_CAMERA_USER=
INTELBRAS_CAMERA_PASSWORD=
INTELBRAS_CAMERA_RTSP_PORT=554
INTELBRAS_CAMERA_CHANNEL=1
INTELBRAS_CAMERA_SUBTYPE=0
INTELBRAS_CAMERA_TIMEOUT_SECONDS=5
INTELBRAS_CAMERA_CAPTURE_FRAME=1

RAG_AUDIT_API_BASE_URL=http://127.0.0.1:8000
RAG_AUDIT_CAMERA_API_KEY=replace-with-the-key-for-cam-ti-01
RAG_AUDIT_VISION_CAMERA_ID=cam-ti-01
RAG_AUDIT_VISION_ROOM_ID=sala_ti_01
RAG_AUDIT_GALLERY_MANIFEST=data/private/gallery/manifest.json
RAG_AUDIT_GALLERY_CACHE_PATH=data/private/cache/{camera_id}/embeddings.arcface.npz
RAG_AUDIT_CAMERA_CALIBRATION=data/private/config/camera-calibration.json
RAG_AUDIT_VISION_MODELS_DIR=data/vision-models
RAG_AUDIT_VISION_MODELS_HOST_DIR=./data/vision-models
# Fingerprint emitido por scripts/prepare_vision_models.py.
RAG_AUDIT_VISION_MODEL_BUNDLE_SHA256=
RAG_AUDIT_VISION_OUTBOX_PATH=data/private/outbox/{camera_id}.db
RAG_AUDIT_VISION_DRY_RUN_OUTBOX_PATH=data/private/outbox/{camera_id}.dry-run.db
RAG_AUDIT_VISION_OUTBOX_SENT_RETENTION_DAYS=30
RAG_AUDIT_VISION_DRY_RUN_OUTBOX_RETENTION_DAYS=7
RAG_AUDIT_VISION_DRY_RUN_OUTBOX_MAX_EVENTS=10000
RAG_AUDIT_VISION_EVIDENCE_DIR=data/private/evidence
RAG_AUDIT_LEARNED_DB_PATH=data/private/learned/learned.db

# entry confirma travessia para dentro. door apenas observa presença junto à porta.
RAG_AUDIT_VISION_MODE=entry
RAG_AUDIT_VISION_ALLOW_DOOR_EVENTS=false
RAG_AUDIT_VISION_MIN_DOOR_FRAMES=4
RAG_AUDIT_VISION_SAMPLE_FPS=4
RAG_AUDIT_VISION_DRY_RUN=true
RAG_AUDIT_VISION_DRY_RUN_SAVE_EVIDENCE=false
RAG_AUDIT_VISION_ROI_PADDING=0.05
RAG_AUDIT_VISION_DECISION_WAIT_SECONDS=1.5
RAG_AUDIT_VISION_DETECTION_SIZE=640x640
RAG_AUDIT_VISION_ONNX_PROVIDERS=CPUExecutionProvider

# Valores iniciais conservadores; calibre com imagens da porta real.
RAG_AUDIT_FACE_SIMILARITY_THRESHOLD=0.55
RAG_AUDIT_FACE_MARGIN_THRESHOLD=0.10
RAG_AUDIT_FACE_QUALITY_THRESHOLD=0.50
RAG_AUDIT_FACE_MIN_INTER_EYE_PIXELS=40
RAG_AUDIT_FACE_FULL_INTER_EYE_PIXELS=80
RAG_AUDIT_FACE_MIN_FOCUS_VARIANCE=20
RAG_AUDIT_FACE_FULL_FOCUS_VARIANCE=260
RAG_AUDIT_FACE_MAX_PITCH_DEGREES=25
RAG_AUDIT_FACE_MAX_YAW_DEGREES=35
RAG_AUDIT_FACE_MAX_ROLL_DEGREES=25

RAG_AUDIT_CONSENSUS_HISTORY_SIZE=12
RAG_AUDIT_CONSENSUS_MIN_MATCHES=4
RAG_AUDIT_CONSENSUS_MIN_RATIO=0.70
RAG_AUDIT_CONSENSUS_MIN_CONSECUTIVE=3

# Quando habilitado, cria somente candidatos PENDING para revisão humana.
RAG_AUDIT_LEARN_ENABLED=false
RAG_AUDIT_LEARN_ALLOW_DRY_RUN=false
RAG_AUDIT_LEARN_MIN_SIMILARITY=0.65
RAG_AUDIT_LEARN_MAX_SIMILARITY=0.95
RAG_AUDIT_LEARN_MIN_MARGIN=0.12
RAG_AUDIT_LEARN_MIN_QUALITY=0.60
RAG_AUDIT_LEARN_MIN_SUPPORTING_FRAMES=4
RAG_AUDIT_LEARN_MAX_PER_PERSON=5
RAG_AUDIT_LEARN_REFRESH_SECONDS=15

RAG_AUDIT_EVIDENCE_TTL_DAYS=30
RAG_AUDIT_EVIDENCE_MAX_GB=10
RAG_AUDIT_EVIDENCE_MAX_ITEM_MB=25
RAG_AUDIT_EVIDENCE_EVICT_OLDEST=true
